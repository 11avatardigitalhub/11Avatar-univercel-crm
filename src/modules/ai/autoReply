 * VERSION: 1.0.0
 * ==========================================
 * 
 * DESCRIPTION:
 * AI-powered auto-reply service for WhatsApp, Email, and SMS.
 * Generates context-aware replies with personalization,
 * sentiment analysis, and follow-up suggestions.
 * 
 * DEPENDENCIES:
 * - aiService.js (for AI capabilities)
 * - eventBus.js (for events)
 * - auditLogger.js (for logging)
 * - logger.js (for logging)
 * - leadScoring.js (for lead context)
 * 
 * FUNCTIONS:
 * - initialize(): Initialize auto-reply
 * - generateReply(message, context): Generate reply
 * - generateWhatsAppReply(message, context): WhatsApp reply
 * - generateEmailReply(message, context): Email reply
 * - generateSMSReply(message, context): SMS reply
 * - generateBulkReplies(messages): Bulk replies
 * - getReplyTemplates(): Get templates
 * - createReplyTemplate(data): Create template
 * - updateReplyTemplate(id, data): Update template
 * - deleteReplyTemplate(id): Delete template
 * - analyzeSentiment(message): Analyze sentiment
 * - getSuggestedActions(message): Get suggested actions
 * - getReplyStats(): Get reply statistics
 * 
 * USAGE EXAMPLE:
 * import { autoReply } from './modules/ai/autoReply.js';
 * 
 * // Initialize auto-reply
 * await autoReply.initialize();
 * 
 * // Generate a reply
 * const reply = await autoReply.generateReply(
 *   'I need more information about your product',
 *   {
 *     name: 'John Doe',
 *     company: 'Tech Solutions',
 *     leadId: 'lead_123',
 *     channel: 'whatsapp'
 *   }
 * );
 * 
 * // Get suggested actions
 * const actions = await autoReply.getSuggestedActions(message);
 * ==========================================
 */

import { aiService } from './aiService.js';
import { leadScoring } from './leadScoring.js';
import { eventBus } from '../../core/events/eventBus.js';
import { logger } from '../../core/monitoring/logger.js';
import { auditLogger } from '../../core/audit/auditLogger.js';
import { tenantIsolation } from '../../core/multitenancy/tenantIsolation.js';

// Reply templates
const DEFAULT_TEMPLATES = [
    {
        id: 'template_welcome',
        name: 'Welcome',
        channel: 'whatsapp',
        category: 'welcome',
        body: 'Welcome {name}! We are excited to have you on board at {company_name}.',
        variables: ['name', 'company_name'],
        isSystem: true,
        createdAt: new Date().toISOString()
    },
    {
        id: 'template_followup',
        name: 'Follow-up',
        channel: 'whatsapp',
        category: 'followup',
        body: 'Hi {name}, this is a follow-up from {company_name}. We would like to connect with you.',
        variables: ['name', 'company_name'],
        isSystem: true,
        createdAt: new Date().toISOString()
    },
    {
        id: 'template_thankyou',
        name: 'Thank You',
        channel: 'whatsapp',
        category: 'thankyou',
        body: 'Thank you {name}! We appreciate your interest in {company_name}.',
        variables: ['name', 'company_name'],
        isSystem: true,
        createdAt: new Date().toISOString()
    },
    {
        id: 'template_enquiry',
        name: 'Enquiry',
        channel: 'whatsapp',
        category: 'enquiry',
        body: 'Thanks for your enquiry, {name}! Our team will get back to you within 24 hours.',
        variables: ['name'],
        isSystem: true,
        createdAt: new Date().toISOString()
    },
    {
        id: 'template_meeting',
        name: 'Meeting Confirmation',
        channel: 'whatsapp',
        category: 'meeting',
        body: 'Hi {name}, your meeting with {company_name} is confirmed for {date_time}.',
        variables: ['name', 'company_name', 'date_time'],
        isSystem: true,
        createdAt: new Date().toISOString()
    }
];

class AutoReply {
    constructor() {
        // Service state
        this.initialized = false;
        this.templates = [...DEFAULT_TEMPLATES];
        this.replyHistory = [];
        
        // Configuration
        this.config = {
            maxHistorySize: 1000,
            enableAI: true,
            enableTemplates: true,
            enableSentimentAnalysis: true,
            enableActionSuggestion: true,
            defaultChannel: 'whatsapp',
            maxReplyLength: 500,
            minConfidence: 0.6,
            fallbackReply: "Thanks for your message! 😊 We'll get back to you shortly."
        };
        
        // Cache
        this.cache = new Map();
        this.cacheTTL = 5 * 60 * 1000;
        this.cacheTimestamps = new Map();
        
        // Statistics
        this.stats = {
            totalReplies: 0,
            aiGenerated: 0,
            templateGenerated: 0,
            byChannel: {
                whatsapp: 0,
                email: 0,
                sms: 0
            },
            byCategory: {},
            averageResponseTime: 0
        };
        
        // Debug mode
        this.debugMode = false;
        
        // Event subscriptions
        this.subscriptions = [];
    }

    /**
     * Initialize auto-reply
     * @param {object} options - Initialization options
     * @returns {boolean} Success status
     */
    async initialize(options = {}) {
        if (this.initialized) {
            return true;
        }

        try {
            // Update config if provided
            if (options.config) {
                this.config = { ...this.config, ...options.config };
            }

            // Load custom templates from storage
            await this.loadCustomTemplates();

            // Setup event listeners
            this.setupEventListeners();

            logger.info('Auto-reply initialized', {
                templates: this.templates.length,
                channels: Object.keys(this.stats.byChannel)
            });

            this.initialized = true;
            return true;
        } catch (error) {
            logger.error('Auto-reply initialization failed:', error);
            throw error;
        }
    }

    /**
     * Setup event listeners
     */
    setupEventListeners() {
        // Auto-reply to WhatsApp messages
        const whatsappSub = eventBus.subscribe('whatsapp.received', async (data) => {
            if (this.config.enableAI && data.text) {
                try {
                    const reply = await this.generateReply(data.text, {
                        from: data.from,
                        leadId: data.leadId,
                        channel: 'whatsapp'
                    });
                    // In production, send the reply via WhatsApp service
                    if (this.debugMode) {
                        logger.debug('[AutoReply] WhatsApp auto-reply generated:', reply);
                    }
                } catch (error) {
                    logger.error('[AutoReply] Auto-reply failed:', error);
                }
            }
        });
        this.subscriptions.push(whatsappSub);

        // Auto-reply to email
        const emailSub = eventBus.subscribe('email.received', async (data) => {
            if (this.config.enableAI && data.body) {
                try {
                    const reply = await this.generateReply(data.body, {
                        from: data.from,
                        customerId: data.customerId,
                        channel: 'email'
                    });
                    if (this.debugMode) {
                        logger.debug('[AutoReply] Email auto-reply generated:', reply);
                    }
                } catch (error) {
                    logger.error('[AutoReply] Auto-reply failed:', error);
                }
            }
        });
        this.subscriptions.push(emailSub);
    }

    /**
     * Load custom templates from storage
     */
    async loadCustomTemplates() {
        // In production, this would load from Firestore
        // For MVP, use default templates
        if (this.debugMode) {
            logger.debug('[AutoReply] Custom templates loaded');
        }
    }

    /**
     * Generate a reply
     * @param {string} message - Incoming message
     * @param {object} context - Context data
     * @param {object} options - Additional options
     * @returns {string} Generated reply
     */
    async generateReply(message, context = {}, options = {}) {
        if (!this.initialized) {
            throw new Error('Auto-reply not initialized');
        }

        const startTime = Date.now();

        // Check cache
        const cacheKey = this.getCacheKey(message, context);
        if (this.cache.has(cacheKey)) {
            const cached = this.cache.get(cacheKey);
            const timestamp = this.cacheTimestamps.get(cacheKey) || 0;
            if (Date.now() - timestamp < this.cacheTTL) {
                return cached;
            }
            this.cache.delete(cacheKey);
            this.cacheTimestamps.delete(cacheKey);
        }

        let reply;

        try {
            // Try template-based reply first
            if (this.config.enableTemplates && options.useTemplates !== false) {
                const templateReply = await this.generateTemplateReply(message, context);
                if (templateReply) {
                    reply = templateReply;
                    this.stats.templateGenerated++;
                }
            }

            // If no template, use AI
            if (!reply && this.config.enableAI && options.useAI !== false) {
                const channel = context.channel || this.config.defaultChannel;
                reply = await this.generateAIReply(message, context, channel);
                this.stats.aiGenerated++;
            }

            // If still no reply, use fallback
            if (!reply) {
                reply = this.config.fallbackReply;
            }

            // Personalize reply
            reply = this.personalizeReply(reply, context);

            // Validate length
            if (reply.length > this.config.maxReplyLength) {
                reply = reply.substring(0, this.config.maxReplyLength);
            }

            // Cache the result
            this.cache.set(cacheKey, reply);
            this.cacheTimestamps.set(cacheKey, Date.now());

            // Update stats
            const duration = Date.now() - startTime;
            this.updateStats(context.channel || 'whatsapp', duration);

            // Log to audit
            await auditLogger.log(
                context.userId || 'system',
                'ai.auto_reply',
                'ai',
                { 
                    message: message.substring(0, 100),
                    reply: reply.substring(0, 100),
                    channel: context.channel
                }
            );

            // Emit event
            eventBus.publish('auto.reply.generated', {
                message: message,
                reply: reply,
                context: context
            });

            if (this.debugMode) {
                logger.debug(`[AutoReply] Reply generated (${duration}ms)`);
            }

            return reply;
        } catch (error) {
            logger.error('[AutoReply] Generation failed:', error);
            return this.config.fallbackReply;
        }
    }

    /**
     * Generate template-based reply
     * @param {string} message - Incoming message
     * @param {object} context - Context data
     * @returns {string|null} Template reply
     */
    async generateTemplateReply(message, context) {
        const matchedTemplates = this.templates.filter(t => 
            t.channel === (context.channel || this.config.defaultChannel) &&
            t.isActive !== false
        );

        if (matchedTemplates.length === 0) {
            return null;
        }

        // Simple matching based on keywords
        const lowerMessage = message.toLowerCase();
        const keywordMap = {
            'welcome': ['welcome', 'hello', 'hi', 'hey'],
            'followup': ['follow', 'update', 'check'],
            'thankyou': ['thank', 'thanks', 'appreciate'],
            'enquiry': ['enquiry', 'query', 'question', 'info'],
            'meeting': ['meeting', 'schedule', 'call', 'appointment']
        };

        for (const template of matchedTemplates) {
            const keywords = keywordMap[template.category] || [];
            if (keywords.some(keyword => lowerMessage.includes(keyword))) {
                return this.renderTemplate(template, context);
            }
        }

        return null;
    }

    /**
     * Render template with variables
     * @param {object} template - Template object
     * @param {object} context - Context data
     * @returns {string} Rendered template
     */
    renderTemplate(template, context) {
        let rendered = template.body;
        const variables = template.variables || [];

        for (const variable of variables) {
            const value = context[variable] || '';
            rendered = rendered.replace(`{${variable}}`, value);
        }

        return rendered;
    }

    /**
     * Generate AI-powered reply
     * @param {string} message - Incoming message
     * @param {object} context - Context data
     * @param {string} channel - Communication channel
     * @returns {string} AI reply
     */
    async generateAIReply(message, context, channel) {
        const prompt = this.buildAIPrompt(message, context, channel);
        
        const response = await aiService.callAI(prompt, {
            temperature: 0.7,
            maxTokens: 200
        });

        return response.trim();
    }

    /**
     * Build AI prompt
     * @param {string} message - Incoming message
     * @param {object} context - Context data
     * @param {string} channel - Communication channel
     * @returns {string} Prompt
     */
    buildAIPrompt(message, context, channel) {
        const name = context.name || 'Customer';
        const company = context.company || 'our company';
        const leadScore = context.score || 'unknown';

        let channelPrompt = '';
        switch (channel) {
            case 'whatsapp':
                channelPrompt = 'Generate a professional WhatsApp reply in Hinglish (Hindi + English). Keep it short and friendly.';
                break;
            case 'email':
                channelPrompt = 'Generate a professional email reply. Use proper formatting and a professional tone.';
                break;
            case 'sms':
                channelPrompt = 'Generate a short SMS reply. Keep it under 160 characters.';
                break;
            default:
                channelPrompt = 'Generate a professional reply.';
        }

        return `
You are an AI sales assistant for an Indian business.

${channelPrompt}

Customer Message: "${message}"
Customer Name: ${name}
Company: ${company}
Lead Score: ${leadScore}

Guidelines:
- Be professional but friendly
- Ask qualifying questions if appropriate
- Suggest next steps
- Keep it under 100 words
- Include emojis appropriately (for WhatsApp)
- Add a call-to-action

Reply:
`;
    }

    /**
     * Personalize reply
     * @param {string} reply - Reply text
     * @param {object} context - Context data
     * @returns {string} Personalized reply
     */
    personalizeReply(reply, context) {
        let personalized = reply;
        
        // Replace placeholders
        if (context.name) {
            personalized = personalized.replace(/{name}/g, context.name);
        }
        if (context.company) {
            personalized = personalized.replace(/{company}/g, context.company);
        }
        if (context.date_time) {
            personalized = personalized.replace(/{date_time}/g, context.date_time);
        }

        return personalized;
    }

    /**
     * Generate WhatsApp-specific reply
     * @param {string} message - Incoming message
     * @param {object} context - Context data
     * @param {object} options - Additional options
     * @returns {string} WhatsApp reply
     */
    async generateWhatsAppReply(message, context = {}, options = {}) {
        context.channel = 'whatsapp';
        return await this.generateReply(message, context, options);
    }

    /**
     * Generate Email reply
     * @param {string} message - Incoming message
     * @param {object} context - Context data
     * @param {object} options - Additional options
     * @returns {string} Email reply
     */
    async generateEmailReply(message, context = {}, options = {}) {
        context.channel = 'email';
        return await this.generateReply(message, context, options);
    }

    /**
     * Generate SMS reply
     * @param {string} message - Incoming message
     * @param {object} context - Context data
     * @param {object} options - Additional options
     * @returns {string} SMS reply
     */
    async generateSMSReply(message, context = {}, options = {}) {
        context.channel = 'sms';
        const reply = await this.generateReply(message, context, options);
        // SMS length limit
        if (reply.length > 160) {
            return reply.substring(0, 157) + '...';
        }
        return reply;
    }

    /**
     * Generate bulk replies
     * @param {Array} messages - List of messages with context
     * @param {object} options - Additional options
     * @returns {Array} Replies
     */
    async generateBulkReplies(messages, options = {}) {
        const results = [];
        for (const item of messages) {
            try {
                const reply = await this.generateReply(
                    item.message,
                    item.context || {},
                    options
                );
                results.push({ 
                    message: item.message,
                    context: item.context,
                    reply: reply,
                    success: true
                });
            } catch (error) {
                results.push({
                    message: item.message,
                    context: item.context,
                    error: error.message,
                    success: false
                });
            }
        }
        return results;
    }

    /**
     * Analyze sentiment of a message
     * @param {string} message - Message to analyze
     * @param {object} options - Additional options
     * @returns {object} Sentiment analysis
     */
    async analyzeSentiment(message, options = {}) {
        if (!this.config.enableSentimentAnalysis) {
            return { sentiment: 'neutral', score: 0.5 };
        }

        try {
            const prompt = `
Analyze the sentiment of this message and return JSON.

Message: "${message}"

Return JSON:
{
    "sentiment": "positive|negative|neutral",
    "score": 0-1,
    "emotions": ["emotion1", "emotion2"],
    "intent": "sales|support|feedback|general"
}
`;

            const response = await aiService.callAI(prompt, {
                temperature: 0.3,
                maxTokens: 100
            });

            try {
                return JSON.parse(response);
            } catch {
                return { sentiment: 'neutral', score: 0.5, emotions: [], intent: 'general' };
            }
        } catch (error) {
            logger.error('[AutoReply] Sentiment analysis failed:', error);
            return { sentiment: 'neutral', score: 0.5, emotions: [], intent: 'general' };
        }
    }

    /**
     * Get suggested actions based on message
     * @param {string} message - Incoming message
     * @param {object} options - Additional options
     * @returns {Array} Suggested actions
     */
    async getSuggestedActions(message, options = {}) {
        if (!this.config.enableActionSuggestion) {
            return [];
        }

        try {
            const prompt = `
Based on this customer message, suggest 3-5 actions.

Message: "${message}"

Return JSON array of actions:
[
    {
        "action": "action name",
        "priority": "high|medium|low",
        "description": "what to do",
        "reason": "why this action"
    }
]
`;

            const response = await aiService.callAI(prompt, {
                temperature: 0.4,
                maxTokens: 200
            });

            try {
                return JSON.parse(response);
            } catch {
                return [
                    {
                        action: 'Follow up',
                        priority: 'medium',
                        description: 'Reply to the customer',
                        reason: 'Customer reached out'
                    }
                ];
            }
        } catch (error) {
            logger.error('[AutoReply] Action suggestion failed:', error);
            return [
                {
                    action: 'Reply to customer',
                    priority: 'medium',
                    description: 'Respond to the message',
                    reason: 'Customer engagement detected'
                }
            ];
        }
    }

    /**
     * Get reply templates
     * @param {object} options - Additional options
     * @returns {Array} Templates
     */
    async getReplyTemplates(options = {}) {
        let templates = [...this.templates];

        if (options.channel) {
            templates = templates.filter(t => t.channel === options.channel);
        }

        if (options.category) {
            templates = templates.filter(t => t.category === options.category);
        }

        if (options.isSystem !== undefined) {
            templates = templates.filter(t => t.isSystem === options.isSystem);
        }

        return templates;
    }

    /**
     * Create reply template
     * @param {object} data - Template data
     * @param {object} options - Additional options
     * @returns {object} Created template
     */
    async createReplyTemplate(data, options = {}) {
        if (!data.name || !data.body) {
            throw new Error('Template name and body are required');
        }

        // Extract variables from body
        const variables = (data.body.match(/{([^}]+)}/g) || []).map(m => m.slice(1, -1));

        const template = {
            id: 'template_' + Date.now() + '_' + Math.random().toString(36).substr(2, 6),
            name: data.name,
            channel: data.channel || this.config.defaultChannel,
            category: data.category || 'general',
            body: data.body,
            variables: variables,
            isSystem: false,
            isActive: true,
            createdBy: options.userId || 'system',
            createdAt: new Date().toISOString(),
            updatedAt: new Date().toISOString()
        };

        this.templates.push(template);

        // Log to audit
        await auditLogger.log(
            options.userId || 'system',
            'auto_reply.template_created',
            'ai',
            { templateId: template.id, name: template.name }
        );

        if (this.debugMode) {
            logger.debug(`[AutoReply] Template created: ${template.id}`);
        }

        return template;
    }

    /**
     * Update reply template
     * @param {string} id - Template ID
     * @param {object} data - Updated data
     * @param {object} options - Additional options
     * @returns {object} Updated template
     */
    async updateReplyTemplate(id, data, options = {}) {
        const index = this.templates.findIndex(t => t.id === id);
        if (index === -1) {
            throw new Error(`Template ${id} not found`);
        }

        const template = this.templates[index];
        if (template.isSystem && !options.forceUpdate) {
            throw new Error('Cannot update system template');
        }

        // Update fields
        if (data.name) template.name = data.name;
        if (data.channel) template.channel = data.channel;
        if (data.category) template.category = data.category;
        if (data.body) {
            template.body = data.body;
            template.variables = (data.body.match(/{([^}]+)}/g) || []).map(m => m.slice(1, -1));
        }
        if (data.isActive !== undefined) template.isActive = data.isActive;

        template.updatedAt = new Date().toISOString();
        this.templates[index] = template;

        // Log to audit
        await auditLogger.log(
            options.userId || 'system',
            'auto_reply.template_updated',
            'ai',
            { templateId: id }
        );

        return template;
    }

    /**
     * Delete reply template
     * @param {string} id - Template ID
     * @param {object} options - Additional options
     * @returns {boolean} Success
     */
    async deleteReplyTemplate(id, options = {}) {
        const index = this.templates.findIndex(t => t.id === id);
        if (index === -1) {
            throw new Error(`Template ${id} not found`);
        }

        const template = this.templates[index];
        if (template.isSystem && !options.forceDelete) {
            throw new Error('Cannot delete system template');
        }

        this.templates.splice(index, 1);

        // Log to audit
        await auditLogger.log(
            options.userId || 'system',
            'auto_reply.template_deleted',
            'ai',
            { templateId: id, name: template.name }
        );

        return true;
    }

    /**
     * Get reply statistics
     * @param {object} options - Additional options
     * @returns {object} Reply statistics
     */
    async getReplyStats(options = {}) {
        return { ...this.stats };
    }

    /**
     * Get cache key
     * @param {string} message - Message
     * @param {object} context - Context
     * @returns {string} Cache key
     */
    getCacheKey(message, context) {
        const keyParts = [
            message.substring(0, 50),
            context.channel || '',
            context.name || ''
        ];
        return 'reply_' + keyParts.join('_').replace(/\s/g, '_');
    }

    /**
     * Update statistics
     * @param {string} channel - Communication channel
     * @param {number} duration - Response time in ms
     */
    updateStats(channel, duration) {
        this.stats.totalReplies++;
        this.stats.byChannel[channel] = (this.stats.byChannel[channel] || 0) + 1;
        
        // Update average response time (moving average)
        const currentAvg = this.stats.averageResponseTime;
        const total = this.stats.totalReplies;
        this.stats.averageResponseTime = ((currentAvg * (total - 1)) + duration) / total;
    }

    /**
     * Enable debug mode
     */
    enableDebug() {
        this.debugMode = true;
        logger.debug('[AutoReply] Debug mode enabled');
    }

    /**
     * Disable debug mode
     */
    disableDebug() {
        this.debugMode = false;
    }

    /**
     * Update configuration
     * @param {object} newConfig - New configuration
     */
    updateConfig(newConfig) {
        this.config = { ...this.config, ...newConfig };
    }

    /**
     * Get configuration
     * @returns {object} Current configuration
     */
    getConfig() {
        return { ...this.config };
    }

    /**
     * Cleanup service resources
     */
    cleanup() {
        // Unsubscribe from events
        for (const subscription of this.subscriptions) {
            if (typeof subscription === 'function') {
                subscription();
            }
        }
        this.subscriptions = [];

        // Clear cache
        this.cache.clear();
        this.cacheTimestamps.clear();

        this.initialized = false;
        logger.info('Auto-reply cleaned up');
    }
}

// Create and export singleton instance
export const autoReply = new AutoReply();

// Export class for testing
export default AutoReply;
