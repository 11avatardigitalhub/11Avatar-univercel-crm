import { aiService } from './aiService.js';
import { eventBus } from '../../core/events/eventBus.js';
import { logger } from '../../core/monitoring/logger.js';
import { auditLogger } from '../../core/audit/auditLogger.js';
import { tenantIsolation } from '../../core/multitenancy/tenantIsolation.js';

// Default deal stages and their base probabilities
const DEFAULT_STAGES = {
    'new': 10,
    'contacted': 20,
    'qualified': 30,
    'negotiation': 50,
    'proposal': 60,
    'verbal_yes': 80,
    'invoice': 85,
    'won': 100,
    'lost': 0
};

// Stage order for progression analysis
const STAGE_ORDER = ['new', 'contacted', 'qualified', 'negotiation', 'proposal', 'verbal_yes', 'invoice'];

// Default risk factors
const DEFAULT_RISK_FACTORS = [
    { id: 'no_owner', name: 'No Owner Assigned', weight: 15 },
    { id: 'old_deal', name: 'Deal Age > 60 Days', weight: 20 },
    { id: 'low_engagement', name: 'Low Engagement', weight: 15 },
    { id: 'competitors', name: 'Competitors Present', weight: 10 },
    { id: 'low_value', name: 'Low Deal Value (< ₹1L)', weight: 5 },
    { id: 'no_timeline', name: 'No Timeline Defined', weight: 10 },
    { id: 'stalled', name: 'No Activity > 7 Days', weight: 15 },
    { id: 'multiple_stakeholders', name: 'Multiple Decision Makers', weight: 10 }
];

class DealPrediction {
    constructor() {
        // Service state
        this.initialized = false;
        this.model = {
            stages: { ...DEFAULT_STAGES },
            stageOrder: [...STAGE_ORDER],
            riskFactors: [...DEFAULT_RISK_FACTORS],
            weights: {
                stage: 0.3,
                value: 0.2,
                age: 0.15,
                engagement: 0.15,
                competitors: 0.1,
                sentiment: 0.1
            },
            thresholds: {
                highProbability: 70,
                mediumProbability: 40,
                lowProbability: 20
            }
        };
        
        // Historical data for model training
        this.historicalData = [];
        this.trainingData = [];
        
        // Cache
        this.cache = new Map();
        this.cacheTTL = 5 * 60 * 1000;
        this.cacheTimestamps = new Map();
        
        // Statistics
        this.stats = {
            totalPredictions: 0,
            successfulPredictions: 0,
            failedPredictions: 0,
            averageProbability: 0,
            byStage: {},
            byOutcome: {},
            accuracy: 0,
            lastTraining: null
        };
        
        // Debug mode
        this.debugMode = false;
    }

    /**
     * Initialize deal prediction
     * @param {object} options - Initialization options
     * @returns {boolean} Success status
     */
    async initialize(options = {}) {
        if (this.initialized) {
            return true;
        }

        try {
            // Update model if provided
            if (options.model) {
                this.model = { ...this.model, ...options.model };
            }

            // Load historical data
            await this.loadHistoricalData();

            // Train model if data available
            if (this.historicalData.length > 0) {
                await this.trainModel();
            }

            // Setup event listeners
            this.setupEventListeners();

            logger.info('Deal prediction initialized', {
                stages: Object.keys(this.model.stages).length,
                riskFactors: this.model.riskFactors.length,
                historicalData: this.historicalData.length
            });

            this.initialized = true;
            return true;
        } catch (error) {
            logger.error('Deal prediction initialization failed:', error);
            throw error;
        }
    }

    /**
     * Setup event listeners
     */
    setupEventListeners() {
        // Auto-predict deals when created
        const dealCreatedSub = eventBus.subscribe('deal.created', async (data) => {
            if (data.deal) {
                try {
                    await this.predictDeal(data.deal);
                } catch (error) {
                    logger.error('[DealPrediction] Auto-prediction failed:', error);
                }
            }
        });
        this.subscriptions.push(dealCreatedSub);

        // Auto-predict deals when updated
        const dealUpdatedSub = eventBus.subscribe('deal.updated', async (data) => {
            if (data.deal) {
                try {
                    await this.predictDeal(data.deal);
                } catch (error) {
                    logger.error('[DealPrediction] Auto-prediction failed:', error);
                }
            }
        });
        this.subscriptions.push(dealUpdatedSub);
    }

    /**
     * Load historical data from storage
     */
    async loadHistoricalData() {
        // In production, this would load from Firestore
        // For MVP, use sample data
        this.historicalData = [
            { stage: 'negotiation', value: 500000, age: 30, engagement: 8, competitors: 2, outcome: 'won' },
            { stage: 'proposal', value: 250000, age: 15, engagement: 5, competitors: 1, outcome: 'won' },
            { stage: 'qualified', value: 100000, age: 45, engagement: 3, competitors: 3, outcome: 'lost' },
            { stage: 'new', value: 50000, age: 5, engagement: 2, competitors: 0, outcome: 'lost' },
            { stage: 'verbal_yes', value: 1000000, age: 20, engagement: 10, competitors: 0, outcome: 'won' }
        ];
        if (this.debugMode) {
            logger.debug('[DealPrediction] Historical data loaded');
        }
    }

    /**
     * Predict a deal
     * @param {object} dealData - Deal data
     * @param {object} options - Additional options
     * @returns {object} Prediction result
     */
    async predictDeal(dealData, options = {}) {
        if (!this.initialized) {
            throw new Error('Deal prediction not initialized');
        }

        const startTime = Date.now();

        // Check cache
        const cacheKey = this.getCacheKey(dealData);
        if (this.cache.has(cacheKey)) {
            const cached = this.cache.get(cacheKey);
            const timestamp = this.cacheTimestamps.get(cacheKey) || 0;
            if (Date.now() - timestamp < this.cacheTTL) {
                return { ...cached };
            }
            this.cache.delete(cacheKey);
            this.cacheTimestamps.delete(cacheKey);
        }

        try {
            // Calculate predictions
            const prediction = await this.calculatePrediction(dealData);

            // Use AI for enhanced prediction if available
            if (options.useAI !== false) {
                try {
                    const aiPrediction = await this.getAIPrediction(dealData);
                    prediction.aiEnhanced = true;
                    prediction.aiProbability = aiPrediction.probability;
                    prediction.probability = Math.round((prediction.probability + aiPrediction.probability) / 2);
                    prediction.aiInsights = aiPrediction.insights;
                } catch (error) {
                    logger.warn('[DealPrediction] AI prediction failed, using rule-based:', error);
                    prediction.aiEnhanced = false;
                }
            } else {
                prediction.aiEnhanced = false;
            }

            // Add additional insights
            prediction.health = await this.getDealHealth(dealData);
            prediction.riskFactors = await this.getRiskFactors(dealData);
            prediction.recommendedActions = await this.getRecommendedActions(dealData, prediction);
            prediction.forecast = await this.getRevenueForecast(dealData);

            // Cache the result
            this.cache.set(cacheKey, prediction);
            this.cacheTimestamps.set(cacheKey, Date.now());

            // Update stats
            const duration = Date.now() - startTime;
            this.updateStats(prediction, duration);

            // Log to audit
            await auditLogger.log(
                options.userId || 'system',
                'ai.deal_prediction',
                'ai',
                { 
                    dealId: dealData.id,
                    probability: prediction.probability,
                    expectedClose: prediction.expectedClose
                }
            );

            // Emit event
            eventBus.publish('deal.predicted', {
                dealId: dealData.id,
                prediction: prediction
            });

            if (this.debugMode) {
                logger.debug(`[DealPrediction] Prediction generated (${duration}ms)`);
            }

            return prediction;
        } catch (error) {
            logger.error('[DealPrediction] Prediction generation failed:', error);
            this.stats.failedPredictions++;
            return this.getFallbackPrediction(dealData);
        }
    }

    /**
     * Calculate prediction based on rules
     * @param {object} dealData - Deal data
     * @returns {object} Prediction
     */
    async calculatePrediction(dealData) {
        const stage = dealData.stage || 'new';
        const value = dealData.value || 0;
        const age = dealData.age || 0;
        const engagement = dealData.engagement || 0;
        const competitors = dealData.competitors || 0;
        const sentiment = dealData.sentiment || 0.5;

        // Base probability from stage
        const baseProbability = this.model.stages[stage] || 10;

        // Value factor (higher value = more complex = slightly lower probability)
        const valueFactor = value > 1000000 ? 0.9 : value > 500000 ? 0.95 : 1.0;

        // Age factor (older deals are riskier)
        const ageFactor = age > 60 ? 0.7 : age > 30 ? 0.85 : 1.0;

        // Engagement factor
        const engagementFactor = engagement > 8 ? 1.1 : engagement > 5 ? 1.0 : engagement > 3 ? 0.9 : 0.8;

        // Competitors factor
        const competitorFactor = competitors === 0 ? 1.0 : competitors === 1 ? 0.95 : competitors === 2 ? 0.85 : 0.7;

        // Sentiment factor
        const sentimentFactor = 0.8 + (sentiment * 0.4);

        // Calculate weighted probability
        let probability = baseProbability * valueFactor * ageFactor * engagementFactor * competitorFactor * sentimentFactor;

        // Ensure within 0-100
        probability = Math.min(100, Math.max(0, probability));

        // Calculate expected close date
        const expectedClose = this.calculateExpectedClose(dealData, probability);

        return {
            probability: Math.round(probability),
            expectedClose: expectedClose,
            stage: stage,
            value: value,
            age: age,
            engagement: engagement,
            competitors: competitors,
            confidence: this.calculateConfidence(dealData),
            factors: {
                stage: { value: baseProbability, impact: 'high' },
                value: { value: valueFactor, impact: 'medium' },
                age: { value: ageFactor, impact: 'medium' },
                engagement: { value: engagementFactor, impact: 'high' },
                competitors: { value: competitorFactor, impact: 'low' },
                sentiment: { value: sentimentFactor, impact: 'medium' }
            }
        };
    }

    /**
     * Calculate expected close date
     * @param {object} dealData - Deal data
     * @param {number} probability - Deal probability
     * @returns {string} Expected close date
     */
    calculateExpectedClose(dealData, probability) {
        const now = new Date();
        const stage = dealData.stage || 'new';
        const stageIndex = this.model.stageOrder.indexOf(stage);
        const remainingStages = this.model.stageOrder.length - stageIndex - 1;

        // Average days per stage (in production, this would be from historical data)
        const avgDaysPerStage = 7;
        const baseDays = remainingStages * avgDaysPerStage;

        // Adjust based on probability
        const probabilityFactor = (100 - probability) / 100;
        const days = Math.max(1, Math.round(baseDays * (0.5 + probabilityFactor * 0.5)));

        const closeDate = new Date(now);
        closeDate.setDate(closeDate.getDate() + days);

        return closeDate.toISOString();
    }

    /**
     * Calculate confidence level
     * @param {object} dealData - Deal data
     * @returns {number} Confidence (0-100)
     */
    calculateConfidence(dealData) {
        let confidence = 60;

        // More data = higher confidence
        if (dealData.id) confidence += 5;
        if (dealData.customerId) confidence += 5;
        if (dealData.assignedTo) confidence += 5;
        if (dealData.products && dealData.products.length > 0) confidence += 5;
        if (dealData.tags && dealData.tags.length > 0) confidence += 5;

        // Engagement increases confidence
        if (dealData.engagement > 5) confidence += 10;
        if (dealData.engagement > 3) confidence += 5;

        return Math.min(100, confidence);
    }

    /**
     * Get AI-enhanced prediction
     * @param {object} dealData - Deal data
     * @returns {object} AI prediction
     */
    async getAIPrediction(dealData) {
        const prompt = `
Predict deal outcome based on:

Deal Details:
Title: ${dealData.title || 'Unknown'}
Value: ₹${dealData.value || 0}
Stage: ${dealData.stage || 'new'}
Age: ${dealData.age || 0} days
Engagement: ${dealData.engagement || 0} interactions
Competitors: ${dealData.competitors || 0}
Sentiment: ${dealData.sentiment || 0.5}

Return JSON:
{
    "probability": 0-100,
    "insights": ["insight1", "insight2"],
