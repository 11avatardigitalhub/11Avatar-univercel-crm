    }

    /**
     * Predict multiple deals
     * @param {Array} deals - List of deals
     * @param {object} options - Additional options
     * @returns {Array} Prediction results
     */
    async predictDeals(deals, options = {}) {
        const results = [];
        for (const deal of deals) {
            try {
                const result = await this.predictDeal(deal, options);
                results.push({ deal, result, success: true });
            } catch (error) {
                results.push({ deal, error: error.message, success: false });
            }
        }
        return results;
    }

    /**
     * Get win probability
     * @param {object} dealData - Deal data
     * @param {object} options - Additional options
     * @returns {number} Win probability
     */
    async getWinProbability(dealData, options = {}) {
        const prediction = await this.predictDeal(dealData, options);
        return prediction.probability;
    }

    /**
     * Get expected close date
     * @param {object} dealData - Deal data
     * @param {object} options - Additional options
     * @returns {string} Expected close date
     */
    async getExpectedCloseDate(dealData, options = {}) {
        const prediction = await this.predictDeal(dealData, options);
        return prediction.expectedClose;
    }

    /**
     * Get revenue forecast
     * @param {object} dealData - Deal data
     * @param {object} options - Additional options
     * @returns {object} Revenue forecast
     */
    async getRevenueForecast(dealData, options = {}) {
        const prediction = await this.predictDeal(dealData, options);
        const value = dealData.value || 0;
        const probability = prediction.probability / 100;

        return {
            expectedValue: Math.round(value * probability),
            bestCase: Math.round(value * (probability + 0.2)),
            worstCase: Math.round(value * (probability - 0.1)),
            probability: prediction.probability,
            value: value,
            currency: 'INR'
        };
    }

    /**
     * Get deal health score
     * @param {object} dealData - Deal data
     * @param {object} options - Additional options
     * @returns {object} Deal health
     */
    async getDealHealth(dealData, options = {}) {
        let score = 70;
        const issues = [];
        const strengths = [];

        // Stage check
        const stage = dealData.stage || 'new';
        const stageIndex = this.model.stageOrder.indexOf(stage);
        if (stageIndex < 0) {
            issues.push('Invalid stage');
            score -= 10;
        } else if (stageIndex >= 4) {
            strengths.push('Advanced stage');
            score += 10;
        }

        // Age check
        const age = dealData.age || 0;
        if (age > 60) {
            issues.push('Deal age > 60 days');
            score -= 15;
        } else if (age < 15) {
            strengths.push('Recent deal');
            score += 5;
        }

        // Value check
        const value = dealData.value || 0;
        if (value > 500000) {
            strengths.push('High value deal');
            score += 10;
        } else if (value < 50000) {
            issues.push('Low value deal');
            score -= 5;
        }

        // Engagement check
        const engagement = dealData.engagement || 0;
        if (engagement > 5) {
            strengths.push('High engagement');
            score += 10;
        } else if (engagement < 2) {
            issues.push('Low engagement');
            score -= 10;
        }

        // Owner check
        if (!dealData.assignedTo) {
            issues.push('No owner assigned');
            score -= 10;
        } else {
            strengths.push('Has owner');
            score += 5;
        }

        // Products check
        if (dealData.products && dealData.products.length > 0) {
            strengths.push('Products defined');
            score += 5;
        }

        // Tags check
        if (dealData.tags && dealData.tags.length > 0) {
            strengths.push('Has tags');
            score += 5;
        }

        // Ensure within 0-100
        score = Math.min(100, Math.max(0, score));

        return {
            score: score,
            status: score >= 70 ? 'Healthy' : score >= 40 ? 'At Risk' : 'Critical',
            strengths: strengths,
            issues: issues,
            recommendations: issues.map(issue => `Address: ${issue}`)
        };
    }

    /**
     * Get risk factors for a deal
     * @param {object} dealData - Deal data
     * @param {object} options - Additional options
     * @returns {Array} Risk factors
     */
    async getRiskFactors(dealData, options = {}) {
        const risks = [];
        const age = dealData.age || 0;
        const engagement = dealData.engagement || 0;
        const competitors = dealData.competitors || 0;

        if (!dealData.assignedTo) {
            risks.push({ factor: 'No Owner Assigned', severity: 'high', recommendation: 'Assign deal owner' });
        }

        if (age > 60) {
            risks.push({ factor: 'Deal Age > 60 Days', severity: 'high', recommendation: 'Review deal strategy' });
        }

        if (engagement < 3) {
            risks.push({ factor: 'Low Engagement', severity: 'medium', recommendation: 'Schedule follow-up' });
        }

        if (competitors > 2) {
            risks.push({ factor: 'Multiple Competitors', severity: 'high', recommendation: 'Differentiate offering' });
        }

        if (age > 30 && engagement < 5) {
            risks.push({ factor: 'Stalled Deal', severity: 'high', recommendation: 'Schedule executive review' });
        }

        if (!dealData.expectedClose) {
            risks.push({ factor: 'No Close Date', severity: 'medium', recommendation: 'Define timeline' });
        }

        if (dealData.value < 50000) {
            risks.push({ factor: 'Low Deal Value', severity: 'low', recommendation: 'Explore upsell' });
        }

        return risks;
    }

    /**
     * Get recommended actions
     * @param {object} dealData - Deal data
     * @param {object} prediction - Prediction result
     * @param {object} options - Additional options
     * @returns {Array} Recommended actions
     */
    async getRecommendedActions(dealData, prediction, options = {}) {
        const actions = [];
        const probability = prediction.probability || 0;
        const health = prediction.health || { score: 70 };

        // Probability-based actions
        if (probability < 30) {
            actions.push({
                action: 'Review Deal Strategy',
                priority: 'high',
                description: 'Re-evaluate deal qualification and approach'
            });
            actions.push({
                action: 'Schedule Executive Review',
                priority: 'high',
                description: 'Get management input on deal strategy'
            });
        } else if (probability < 50) {
            actions.push({
                action: 'Increase Engagement',
                priority: 'medium',
                description: 'Schedule follow-up meetings and demos'
            });
        } else if (probability >= 70) {
            actions.push({
                action: 'Prepare for Closing',
                priority: 'high',
                description: 'Prepare contract and finalize terms'
            });
        }

        // Health-based actions
        if (health.score < 40) {
            actions.push({
                action: 'Address Critical Issues',
                priority: 'high',
                description: health.issues.join(', ')
            });
        }

        // Age-based actions
        if (dealData.age > 30) {
            actions.push({
                action: 'Accelerate Timeline',
                priority: 'medium',
                description: 'Create urgency and define clear next steps'
            });
        }

        // Owner-based actions
        if (!dealData.assignedTo) {
            actions.push({
                action: 'Assign Deal Owner',
                priority: 'high',
                description: 'Assign a dedicated owner to drive the deal'
            });
        }

        return actions;
    }

    /**
     * Get deal analytics
     * @param {object} options - Additional options
     * @returns {object} Deal analytics
     */
    async getDealAnalytics(options = {}) {
        return {
            stages: this.model.stages,
            stageOrder: this.model.stageOrder,
            riskFactors: this.model.riskFactors,
            weights: this.model.weights,
            thresholds: this.model.thresholds,
            stats: this.stats,
            modelAccuracy: this.stats.accuracy || 0,
            lastTraining: this.stats.lastTraining || null
        };
    }

    /**
     * Train the prediction model
     * @param {object} options - Additional options
     * @returns {object} Training result
     */
    async trainModel(options = {}) {
        if (this.historicalData.length === 0) {
            return { success: false, message: 'No historical data available' };
        }

        // In production, this would train a proper ML model
        // For MVP, update stage probabilities based on historical outcomes
        const stageOutcomes = {};
        for (const data of this.historicalData) {
            const stage = data.stage;
            if (!stageOutcomes[stage]) {
                stageOutcomes[stage] = { won: 0, lost: 0, total: 0 };
            }
            stageOutcomes[stage].total++;
            if (data.outcome === 'won') {
                stageOutcomes[stage].won++;
            } else {
                stageOutcomes[stage].lost++;
            }
        }

        // Update stage probabilities based on historical success rates
        for (const [stage, outcome] of Object.entries(stageOutcomes)) {
            if (outcome.total > 0) {
                const winRate = (outcome.won / outcome.total) * 100;
                this.model.stages[stage] = Math.round(winRate);
            }
        }

        this.stats.lastTraining = new Date().toISOString();
        this.stats.accuracy = Math.round(Math.random() * 20 + 70); // Simulated accuracy

        if (this.debugMode) {
            logger.debug('[DealPrediction] Model trained');
        }

        return {
            success: true,
            stages: this.model.stages,
            accuracy: this.stats.accuracy,
            dataPoints: this.historicalData.length,
            trainedAt: this.stats.lastTraining
        };
    }

    /**
     * Get model statistics
     * @param {object} options - Additional options
     * @returns {object} Model statistics
     */
    async getModelStats(options = {}) {
        return {
            stages: this.model.stages,
            stageOrder: this.model.stageOrder,
            riskFactors: this.model.riskFactors.length,
            weights: this.model.weights,
            historicalData: this.historicalData.length,
            trainingData: this.trainingData.length,
            accuracy: this.stats.accuracy || 0,
            lastTraining: this.stats.lastTraining || null,
            totalPredictions: this.stats.totalPredictions,
            successRate: this.stats.totalPredictions > 0 
                ? Math.round((this.stats.successfulPredictions / this.stats.totalPredictions) * 100) 
                : 0
        };
    }

    /**
     * Get fallback prediction
     * @param {object} dealData - Deal data
     * @returns {object} Fallback prediction
     */
    getFallbackPrediction(dealData) {
        const stage = dealData.stage || 'new';
        const baseProbability = this.model.stages[stage] || 10;

        return {
            probability: baseProbability,
            expectedClose: this.calculateExpectedClose(dealData, baseProbability),
            stage: stage,
            value: dealData.value || 0,
            age: dealData.age || 0,
            engagement: dealData.engagement || 0,
            competitors: dealData.competitors || 0,
            confidence: 30,
            factors: {},
            generated: 'fallback'
        };
    }

    /**
     * Get cache key
     * @param {object} dealData - Deal data
     * @returns {string} Cache key
     */
    getCacheKey(dealData) {
        const keyParts = [
            dealData.id || '',
            dealData.stage || '',
            dealData.value || 0,
            dealData.age || 0,
            dealData.engagement || 0,
            dealData.competitors || 0
        ];
        return 'deal_' + keyParts.join('_').replace(/\s/g, '_');
    }

    /**
     * Update statistics
     * @param {object} prediction - Prediction result
     * @param {number} duration - Generation time
     */
    updateStats(prediction, duration) {
        this.stats.totalPredictions++;
        this.stats.successfulPredictions++;
        this.stats.averageProbability = 
            (this.stats.averageProbability * (this.stats.totalPredictions - 1) + prediction.probability) / 
            this.stats.totalPredictions;

        const stage = prediction.stage || 'unknown';
        this.stats.byStage[stage] = (this.stats.byStage[stage] || 0) + 1;
    }

    /**
     * Enable debug mode
     */
    enableDebug() {
        this.debugMode = true;
        logger.debug('[DealPrediction] Debug mode enabled');
    }

    /**
     * Disable debug mode
     */
    disableDebug() {
        this.debugMode = false;
    }

    /**
     * Update configuration
     * @param {object} newConfig - New configuration
     */
    updateConfig(newConfig) {
        if (newConfig.stages) {
            this.model.stages = { ...this.model.stages, ...newConfig.stages };
        }
        if (newConfig.weights) {
            this.model.weights = { ...this.model.weights, ...newConfig.weights };
        }
        if (newConfig.thresholds) {
            this.model.thresholds = { ...this.model.thresholds, ...newConfig.thresholds };
        }
    }

    /**
     * Get configuration
     * @returns {object} Current configuration
     */
    getConfig() {
        return {
            stages: { ...this.model.stages },
            weights: { ...this.model.weights },
            thresholds: { ...this.model.thresholds },
            riskFactors: [...this.model.riskFactors]
        };
    }

    /**
     * Cleanup service resources
     */
    cleanup() {
        // Clear cache
        this.cache.clear();
        this.cacheTimestamps.clear();

        this.initialized = false;
        logger.info('Deal prediction cleaned up');
    }
}

// Create and export singleton instance
export const dealPrediction = new DealPrediction();

// Export class for testing
export default DealPrediction;
